# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ─── Xcode ────────────────────────────────────────────────────────────────────
build/
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata/
*.xccheckout
*.moved-aside
DerivedData/
*.hmap
*.ipa
*.xcuserstate
**/.xcode.env.local
ios/.xcode.env.local

# ─── Android / IntelliJ ───────────────────────────────────────────────────────
.idea/
.gradle/
local.properties
*.iml
*.hprof
.cxx/
.kotlin/

# Keystores — keep debug.keystore (checked-in default), exclude everything else
*.keystore
!android/app/debug.keystore

# ─── Google / Firebase ────────────────────────────────────────────────────────
android/app/google-services.json
ios/larksoul/GoogleService-Info.plist

# ─── OAuth & secrets ──────────────────────────────────────────────────────────
# Environment / secret files
.env
.env.*
!.env.example
*.secret
secrets.json
secrets.yaml
secrets.yml

# Auth config with real credentials (keep the template, ignore overrides)
# src/config/auth.config.local.ts

# ─── Node.js ──────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ─── Ruby / CocoaPods ─────────────────────────────────────────────────────────
**/Pods/
/vendor/bundle/

# ─── Fastlane ─────────────────────────────────────────────────────────────────
**/fastlane/report.xml
**/fastlane/Preview.html
**/fastlane/screenshots/
**/fastlane/test_output/
# Fastlane credentials
fastlane/Appfile
fastlane/Matchfile

# ─── Metro / React Native ─────────────────────────────────────────────────────
.metro-health-check*
*.jsbundle
.react-native-cache/

# ─── Testing & coverage ───────────────────────────────────────────────────────
/coverage/
*.lcov

# ─── Editor & IDE ─────────────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── OS generated ─────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ─── Logs & temp ──────────────────────────────────────────────────────────────
*.log
*.tmp
*.temp
tmp/
temp/
